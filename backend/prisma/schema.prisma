generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  password String
  role     UserRole  @default(STUDENT)
  resource Resource? @relation("UserResource")
}

model Resource {
  id               String          @id @default(uuid())
  name             String
  type             ResourceType
  order            Int             @default(0)
  userId           String?         @unique
  startDate        String?         // YYYY-MM-DD
  endDate          String?         // YYYY-MM-DD
  subjects         CourseSubject[] @relation("CourseSubjects")
  lessonsAsCourse  Lesson[]        @relation("CourseLessons")
  lessonsAsRoom    Lesson[]        @relation("RoomLessons")
  lessonsAsTeacher Lesson[]        @relation("TeacherLessons")
  user             User?           @relation("UserResource", fields: [userId], references: [id])
  events           ScheduleEvent[] @relation("ResourceEvents")
  lessonsAsSub     Lesson[]        @relation("SubTeacherLessons")

  // 追加: メイン教室・教官設定
  mainRoomId       String?
  mainRoom         Resource?       @relation("CourseMainRoom", fields: [mainRoomId], references: [id])
  coursesAsMainRoom Resource[]     @relation("CourseMainRoom")
  
  chiefTeacherId   String?
  chiefTeacher     Resource?       @relation("CourseChiefTeacher", fields: [chiefTeacherId], references: [id])
  coursesAsChiefTeacher Resource[] @relation("CourseChiefTeacher")

  assistantTeachers Resource[]    @relation("CourseAssistantTeachers")
  coursesAsAssistant Resource[]    @relation("CourseAssistantTeachers")

  mainTeacherLabel String?
  subTeacherLabel  String?

  courseTypeId     String?
  courseType       CourseType?     @relation(fields: [courseTypeId], references: [id])
}

model CourseType {
  id        String     @id @default(uuid())
  name      String
  order     Int        @default(0)
  startDate String?    // YYYY-MM-DD
  endDate   String?    // YYYY-MM-DD
  subjects  Subject[]
  resources Resource[]
}

model Subject {
  id            String          @id @default(uuid())
  name          String
  level         Int             @default(1) // 1: Large, 2: Middle, 3: Small
  parentId      String?
  parent        Subject?        @relation("SubjectHierarchy", fields: [parentId], references: [id])
  children      Subject[]       @relation("SubjectHierarchy")
  courseTypeId  String
  courseType    CourseType      @relation(fields: [courseTypeId], references: [id], onDelete: Cascade)
  totalPeriods  Int?            // Only for leaf nodes
  order         Int             @default(0)
  courseSubjects CourseSubject[]
  lessons       Lesson[]        @relation("SubjectLessons")
}

model CourseSubject {
  id           String   @id @default(uuid())
  name         String?  // Legacy
  totalPeriods Int?     // Legacy
  resourceId   String
  course       Resource @relation("CourseSubjects", fields: [resourceId], references: [id], onDelete: Cascade)
  subjectId    String?
  subject      Subject? @relation(fields: [subjectId], references: [id])
}

model Lesson {
  id              String           @id @default(uuid())
  subject         String
  subjectId       String?
  subjectRef      Subject?         @relation("SubjectLessons", fields: [subjectId], references: [id])
  startDate       String
  startPeriodId   String
  endDate         String
  endPeriodId     String
  roomId          String?
  teacherId       String?
  courseId        String
  location        String?
  remarks         String?
  externalTeacher String?
  externalSubTeachers String?
  course          Resource         @relation("CourseLessons", fields: [courseId], references: [id])
  room            Resource?        @relation("RoomLessons", fields: [roomId], references: [id])
  teacher         Resource?        @relation("TeacherLessons", fields: [teacherId], references: [id])
  subTeachers     Resource[]       @relation("SubTeacherLessons")
  deliveryMethods DeliveryMethod[] @relation("LessonDeliveryMethods")
}

model DeliveryMethod {
  id      String   @id @default(uuid())
  name    String
  color   String?
  order   Int      @default(0)
  lessons Lesson[] @relation("LessonDeliveryMethods")
}

model ScheduleEvent {
  id             String     @id @default(uuid())
  name           String
  startDate      String
  startPeriodId  String
  endDate        String
  endPeriodId    String
  color          String?
  location       String?
  remarks        String?
  showInEventRow Boolean    @default(true)
  resources      Resource[] @relation("ResourceEvents")
}

model Holiday {
  id    String  @id @default(uuid())
  name  String
  date  String?
  start String?
  end   String?
}

model TimePeriod {
  id        String @id @default(uuid())
  name      String
  startTime String
  endTime   String
  order     Int    @default(0)
}

model ResourceLabel {
  id             String @id @default(uuid())
  room           String @default("Room")
  teacher        String @default("Teacher")
  course         String @default("Course")
  event          String @default("Event")
  mainTeacher    String @default("Main Teacher")
  subTeacher     String @default("Sub Teacher")
  mainRoom       String @default("Main Room")
  deliveryMethod String @default("Delivery Method")
  subject        String @default("Subject")
  courseType     String @default("Course Type")
  subjectLarge   String @default("Subject (Large)")
  subjectMiddle  String @default("Subject (Middle)")
  subjectSmall   String @default("Subject (Small)")
}

model SystemSetting {
  id                 String  @id @default(uuid())
  allowPublicSignup  Boolean @default(true)
  yearViewStartMonth Int     @default(4)
  yearViewStartDay   Int     @default(1)
  weekendDays        String  @default("0,6") // Comma-separated day indices (0=Sun, 6=Sat)
  holidayTheme       String  @default("default")
}

model ColorTheme {
  id         String        @id @default(uuid())
  name       String
  category   ColorCategory
  key        String?       // システムデフォルト識別用 (e.g. "default", "no-teacher")
  background String
  foreground String
  order      Int           @default(0)
}

enum ColorCategory {
  EVENT
  LESSON
  HOLIDAY
}

enum ResourceType {
  room
  teacher
  course
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}
