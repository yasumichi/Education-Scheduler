generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id @default(uuid())
  email    String    @unique
  password String
  role     UserRole  @default(STUDENT)
  resource Resource? @relation("UserResource")
}

model Resource {
  id               String          @id @default(uuid())
  name             String
  type             ResourceType
  order            Int             @default(0)
  userId           String?         @unique
  lessonsAsCourse  Lesson[]        @relation("CourseLessons")
  lessonsAsRoom    Lesson[]        @relation("RoomLessons")
  lessonsAsTeacher Lesson[]        @relation("TeacherLessons")
  user             User?           @relation("UserResource", fields: [userId], references: [id])
  events           ScheduleEvent[] @relation("ResourceEvents")
  lessonsAsSub     Lesson[]        @relation("SubTeacherLessons")
}

model Lesson {
  id            String     @id @default(uuid())
  subject       String
  startDate     String
  startPeriodId String
  endDate       String
  endPeriodId   String
  roomId        String
  teacherId     String
  courseId      String
  course        Resource   @relation("CourseLessons", fields: [courseId], references: [id])
  room          Resource   @relation("RoomLessons", fields: [roomId], references: [id])
  teacher       Resource   @relation("TeacherLessons", fields: [teacherId], references: [id])
  subTeachers   Resource[] @relation("SubTeacherLessons")
}

model ScheduleEvent {
  id             String     @id @default(uuid())
  name           String
  startDate      String
  startPeriodId  String
  endDate        String
  endPeriodId    String
  color          String?
  showInEventRow Boolean    @default(true)
  resources      Resource[] @relation("ResourceEvents")
}

model Holiday {
  id    String  @id @default(uuid())
  name  String
  date  String?
  start String?
  end   String?
}

model TimePeriod {
  id        String @id @default(uuid())
  name      String
  startTime String
  endTime   String
  order     Int    @default(0)
}

model ResourceLabel {
  id          String @id @default(uuid())
  room        String @default("Room")
  teacher     String @default("Teacher")
  course      String @default("Course")
  event       String @default("Event")
  mainTeacher String @default("Main Teacher")
  subTeacher  String @default("Sub Teacher")
}

enum ResourceType {
  room
  teacher
  course
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}
